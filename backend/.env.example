# Copiez ce fichier en .env à la racine du projet

# Secret JWT (changez en production)
JWT_SECRET=votre_secret_jwt_tres_long

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
# Origines JavaScript autorisées (sans /frontend/...) — ex. si vous ouvrez :
#   http://127.0.0.1:5501/frontend/index.html  →  mettez seulement : http://127.0.0.1:5501
# Ajoutez aussi si besoin : http://localhost:5501
GOOGLE_CLIENT_ID=votre_client_id.apps.googleusercontent.com

PORT=3000

# Base MySQL (local ou cloud : Railway, Aiven, PlanetScale, etc.)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gestion_hotel
# Mettre true si le fournisseur exige SSL (souvent le cas en production)
DB_SSL=false
